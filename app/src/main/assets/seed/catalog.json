    { "id": "nethersx2-patch",   "name": "NetherSX2-Patch",   "packageId": "xyz.aethersx2.android",   "platformTargets": ["PS2"],     "sourceUrl": "https://github.com/Trixarian/NetherSX2-patch", "notes": "Build 4248. Best on Adreno GPUs." },
    { "id": "nethersx2-classic", "name": "NetherSX2-Classic", "packageId": "xyz.aethersx2.android",   "platformTargets": ["PS2"],     "sourceUrl": "https://github.com/Trixarian/NetherSX2-classic","notes": "Build 3668. Better on Mali GPUs and weaker chips." },
    { "id": "armsx2",            "name": "ARMSX2",            "packageId": "com.armsx2",              "platformTargets": ["PS2"],     "sourceUrl": "https://github.com/ARMSX2/ARMSX2",              "notes": "Newer PCSX2 fork. Faster on some chips, regressions on others." },

    { "id": "duckstation",       "name": "DuckStation",       "packageId": "com.github.stenzek.duckstation", "platformTargets": ["PS1"], "sourceUrl": "https://duckstation.org",                "notes": "Best PS1 emulator on Android. Locked 60fps on basically any modern device." },

