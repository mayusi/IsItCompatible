  "drivers": [
    { "id": "turnip-adreno8xx-current", "name": "Turnip (Mesa 26.1.x line, AdrenoTools) — Adreno 8xx/Snapdragon 8 Elite", "gpuTargets": ["Adreno 830", "Adreno 840", "Adreno 8 series"], "downloadUrl": "https://github.com/whitebelyash/freedreno_turnip-CI/releases", "sha256": null, "dataAsOf": "2026-06", "notes": "Current AdrenoTools Turnip line. Mesa 26.0+ added Adreno Gen 8 / A8xx (830/840) support; the freedreno_turnip-CI (whitebelyash) and Banners-Turnip repos publish per-commit AdrenoTools-packaged A8xx builds. Pick the latest Mesa 26.1.x .adpkg.zip for your Adreno 8xx GPU. UNVERIFIED: exact pinned build filename + sha256 not captured — confirm against the release page before pinning a hash." },
    { "id": "turnip-24.3.0",     "name": "Turnip 24.3.0 R6 (LEGACY/pinned, Adreno 7xx — outdated for Windows stack)",    "gpuTargets": ["Adreno 750", "Adreno 740", "Adreno 730"], "downloadUrl": "https://github.com/K11MCH1/AdrenoToolsDrivers/releases/download/Turnip-v24.3.0/turnip_v24.3.0_R6.adpkg.zip", "dataAsOf": "2026-06", "notes": "LEGACY pinned build. Superseded by the Mesa 26.1.x line (turnip-adreno8xx-current) for the Windows/GameNative stack and for Adreno 8xx. Retained only for older Adreno 7xx targets and existing console-emulator guide references. Does not reliably support Adreno 830." },
    { "id": "turnip-24.2.0",     "name": "Turnip 24.2.0 R3 (Adreno 7xx)",    "gpuTargets": ["Adreno 750", "Adreno 740", "Adreno 730", "Adreno 660"], "downloadUrl": "https://github.com/K11MCH1/AdrenoToolsDrivers/releases/download/Turnip-v24.2.0/turnip_v24.2.0_R3.adpkg.zip" },
    { "id": "turnip-24.1.0",     "name": "Turnip 24.1.0 (Adreno 6xx+)",      "gpuTargets": ["Adreno 660", "Adreno 650", "Adreno 730"], "downloadUrl": "https://github.com/K11MCH1/AdrenoToolsDrivers/releases" },
    { "id": "turnip-mr31p",      "name": "Turnip mr31.p (dev, Adreno 7xx)",  "gpuTargets": ["Adreno 750", "Adreno 740"], "downloadUrl": "https://github.com/K11MCH1/AdrenoToolsDrivers/releases" },
    { "id": "adreno-stock",      "name": "Stock Adreno driver",              "gpuTargets": ["Adreno 750", "Adreno 740", "Adreno 730", "Adreno 660", "Adreno 650"], "downloadUrl": "" },
    { "id": "vortek",            "name": "Vortek (Universal) — built-in fallback driver in GameNative / Winlator",  "gpuTargets": ["Adreno 830", "Adreno 8 series", "Adreno 8xx"], "downloadUrl": "https://github.com/utkarshdalal/GameNative/releases", "sha256": null, "dataAsOf": "2026-06-08", "notes": "On GameNative, Vortek (Universal) is a built-in entry in the Graphics Driver dropdown (no .zip import needed) and is the default fallback. For Adreno 830 / Snapdragon 8 Elite the preferred path is the 'Wrapper' driver with 'Use Adrenotools Turnip' ON plus a recent Turnip build (matches the real exported config graphicsDriver=wrapper, adrenotoolsTurnip=1); use Vortek or the 'SD 8 Elite' entry only if a game won't render on Turnip. Confirmed against GameNative source app/src/main/res/values/arrays.xml (graphics_driver_entries) and core/DefaultVersion.java." }
  ],
