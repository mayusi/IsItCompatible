            "Resolution": "1x",
            "Async shaders": "On"
          }
        },
        {
          "kind": "FILES",
          "text": "Add your Xenoblade 3 dumped .nsp/.xci + update.",
          "path": "/storage/emulated/0/Switch/"
        },
        {
          "kind": "TIP",
          "text": "Very heavy — expect ~20-30fps. Open fields slower; towns faster."
