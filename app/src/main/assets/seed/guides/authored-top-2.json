    {
      "id": "win:re-village:gamenative:t2",
      "gameId": "win:re-village",
      "emulatorId": "gamenative",
      "tier": 2,
      "sourceLabel": "Authored guide",
      "dataAsOf": "2026-05-29",
      "steps": [
        {
          "kind": "GET_APP",
          "text": "Install GameNative — its Proton support handles RE Engine titles well.",
          "url": "https://github.com/utkarshdalal/GameNative/releases"
        },
        {
          "kind": "GET_DRIVER",
          "text": "Install Turnip 24.3.0 for RE Engine DX12 support.",
          "driverId": "turnip-24.3.0"
        },
        {
          "kind": "CONTAINER",
          "text": "Resident Evil Village settings.",
          "settings": {
            "Proton": "GE-Proton 9.x",
            "Graphics driver": "Turnip 24.3.0",
            "DXVK": "On (2.4-async)",
            "VKD3D": "On (DX12 title)",
            "Box64": "Performance"
          }
        },
        {
          "kind": "FILES",
          "text": "Copy your RE Village folder into the container.",
          "path": "/storage/emulated/0/GameNative/REVillage/"
        },
        {
          "kind": "TIP",
          "text": "Set to 720p Low settings for the best balance. The RE Engine is demanding even on desktop — mobile requires tuning."
        },
        {
          "kind": "ACTION",
          "text": "Launch the game. Expect ~30 fps at 720p Low on a high-end Snapdragon."
        }
      ],
      "troubleshooting": [
        {
          "symptom": "Low FPS or heavy stutter in village areas",
          "fix": "Lower shadow distance and object draw distance in-game; RE Engine's draw calls are CPU-heavy under Box64."
        }
      ]
