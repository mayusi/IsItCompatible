  "guides": [
    {
      "id": "win:fallout-4:winlator-cmod:t2",
      "gameId": "win:fallout-4",
      "emulatorId": "winlator-cmod",
      "tier": 2,
      "sourceLabel": "Authored guide",
      "dataAsOf": "2026-05-29",
      "steps": [
        {
          "kind": "GET_APP",
          "text": "Install Winlator Cmod (latest).",
          "url": "https://github.com/coffincolors/winlator/releases"
        },
        {
          "kind": "GET_DRIVER",
          "text": "Install Turnip 24.3.0 — Fallout 4's Creation Engine DX11 is stable on Turnip.",
          "driverId": "turnip-24.3.0"
        },
        {
          "kind": "CONTAINER",
          "text": "Create a Fallout 4 container with these settings.",
          "settings": {
            "Screen size": "1280x720",
            "Graphics driver": "Turnip 24.3.0",
            "DX wrapper": "DXVK 2.4-async",
            "Box64 preset": "Performance",
            "Wine": "9.4-staging-tkg",
            "Video memory": "Set to ~10 GB for mod support"
          }
        },
        {
          "kind": "FILES",
          "text": "Copy your Fallout 4 folder (the one with Fallout4.exe) into the container.",
          "path": "/storage/emulated/0/Download/Fallout4/"
        },
        {
          "kind": "TIP",
          "text": "Mods are supported via Mod Organizer 2 or Vortex inside the container. Install them before launching for best results."
        },
        {
          "kind": "TIP",
          "text": "Cap FPS to 60 — the Creation Engine physics break above 60 fps. Use in-game settings or external tools."
        },
        {
          "kind": "ACTION",
          "text": "Run Fallout4.exe. Expect 50-60 fps at 720p on a high-end Snapdragon with mods."
        }
      ],
      "troubleshooting": [
        {
          "symptom": "Crash on startup / DXVK init error",
          "fix": "Drop DXVK to 2.3 and relaunch; a few systems have compatibility issues with 2.4-async."
        },
        {
          "symptom": "Physics bugs / falling through terrain",
          "fix": "Confirm FPS cap is at or below 60. The Creation Engine's physics engine is tied to frame rate."
        }
      ]
    },
